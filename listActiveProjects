map listActiveProjects()
{
result = Map();
items = List();
stats = Map();
debug = Map();
api_errors = List();
request_summary = List();
portal_id = "7004368649";
dc_base = "https://projectsapi.zoho.com.au/restapi";
base_url = dc_base + "/portal/" + portal_id + "/projects/";
page_size = 100;
project_pages = 0;
projects_fetched = 0;
projects_included = 0;
projects_excluded_by_status = 0;
projects_excluded_onboarding = 0;
debug.put("portal_id",portal_id);
debug.put("api_errors",api_errors);
debug.put("request_summary",request_summary);
page_markers_text = "x".leftpad(200);
page_markers_text = page_markers_text.replaceAll(" ",",x");
page_markers = page_markers_text.toList(",");
done = false;
for each index page_no in page_markers
{
	if(done == true)
	{
		break;
	}
	start_index = page_no * page_size + 1;
	params_map = Map();
	params_map.put("index",start_index);
	params_map.put("range",page_size);
	resp = Map();
	project_list = List();
	try 
	{
		resp = invokeurl
		[
			url :base_url
			type :GET
			parameters:params_map
			connection:"zoho_project_connection"
		];
		request_summary.add("GET /projects/ index=" + start_index + " range=" + page_size);
	}
	catch (e1)
	{
		err = Map();
		err.put("stage","projects_fetch");
		err.put("index",start_index);
		err.put("message",e1.toString());
		api_errors.add(err);
		done = true;
	}
	try 
	{
		if(resp.containsKey("projects"))
		{
			project_list = resp.get("projects");
		}
		else
		{
			debug.put("projects_raw_unexpected",resp);
			done = true;
		}
	}
	catch (e2)
	{
		err = Map();
		err.put("stage","projects_parse");
		err.put("index",start_index);
		err.put("message",e2.toString());
		api_errors.add(err);
		done = true;
	}
	if(project_pages == 0)
	{
		if(project_list.size() > 0)
		{
			first_project = project_list.get(0);
			debug.put("projects_sample",first_project);
			try 
			{
				debug.put("project_field_keys",first_project.keys());
			}
			catch (ignore_keys)
			{
			}
		}
	}
	project_pages = project_pages + 1;
	projects_fetched = projects_fetched + project_list.size();
	for each  project_rec in project_list
	{
		project_id = "";
		project_name = "";
		project_status = "";
		project_updated_date = "";
		project_owner = "";
		include_project = true;
		excluded_by_onboarding = false;
		try 
		{
			project_id = ifnull(project_rec.get("id"),"").toString();
		}
		catch (e3)
		{
		}
		try 
		{
			project_name = ifnull(project_rec.get("name"),"").toString();
		}
		catch (e4)
		{
		}
		try 
		{
			project_status = ifnull(project_rec.get("status"),"").toString();
		}
		catch (e5)
		{
		}
		try 
		{
			project_updated_date = ifnull(project_rec.get("updated_date"),"").toString();
		}
		catch (e6)
		{
		}
		try 
		{
			project_owner = ifnull(project_rec.get("owner_name"),"").toString();
		}
		catch (e7)
		{
		}
		try 
		{
			if(debug.containsKey("projects_sample_full") == false)
			{
				debug.put("projects_sample_full",project_rec);
			}
		}
		catch (dbg1)
		{
		}
		try 
		{
			if(project_rec.containsKey("custom_fields"))
			{
				if(debug.containsKey("project_custom_fields_sample") == false)
				{
					debug.put("project_custom_fields_sample",project_rec.get("custom_fields"));
				}
			}
		}
		catch (dbg2)
		{
		}
		status_lc = project_status.toLowerCase();
		if(status_lc == "archived")
		{
			include_project = false;
		}
		if(status_lc == "closed")
		{
			include_project = false;
		}
		if(status_lc == "inactive")
		{
			include_project = false;
		}
		if(status_lc == "completed")
		{
			include_project = false;
		}
		if(status_lc == "cancelled")
		{
			include_project = false;
		}
		if(status_lc == "to do")
		{
			include_project = false;
		}
		if(status_lc == "pipeline")
		{
			include_project = false;
		}
		try 
		{
			if(project_rec.containsKey("custom_fields"))
			{
				custom_fields = project_rec.get("custom_fields");
				for each  field_rec in custom_fields
				{
					field_label = "";
					field_value_text = "";
					try 
					{
						field_label = ifnull(field_rec.get("label_name"),"").toString();
					}
					catch (ignore1)
					{
					}
					if(field_label == "Implementation Type")
					{
						try 
						{
							field_value_text = ifnull(field_rec.get("value"),"").toString();
						}
						catch (ignore2)
						{
							field_value_text = "";
						}
						if(field_value_text.toLowerCase().contains("onboarding"))
						{
							include_project = false;
							excluded_by_onboarding = true;
						}
					}
				}
			}
		}
		catch (impl_filter_error)
		{
			err = Map();
			err.put("stage","implementation_type_filter");
			err.put("project_id",project_id);
			err.put("message",impl_filter_error.toString());
			api_errors.add(err);
		}
		if(include_project == true)
		{
			project_item = Map();
			project_item.put("project_id",project_id);
			project_item.put("project_name",project_name);
			project_item.put("status",project_status);
			project_item.put("updated_date",project_updated_date);
			project_item.put("owner",project_owner);
			items.add(project_item);
			projects_included = projects_included + 1;
		}
		else
		{
			if(excluded_by_onboarding == true)
			{
				projects_excluded_onboarding = projects_excluded_onboarding + 1;
			}
			else
			{
				projects_excluded_by_status = projects_excluded_by_status + 1;
			}
		}
	}
	if(project_list.size() < page_size)
	{
		done = true;
	}
}
stats.put("project_pages",project_pages);
stats.put("projects_fetched",projects_fetched);
stats.put("projects_included",projects_included);
stats.put("projects_excluded_by_status",projects_excluded_by_status);
stats.put("projects_excluded_onboarding",projects_excluded_onboarding);
stats.put("api_error_count",api_errors.size());
debug.put("filter_mode","local_filter_exclude_archived_closed_inactive_completed_cancelled_todo_pipeline_and_onboarding");
debug.put("note","Implementation Type filter uses custom field label_name = 'Implementation Type' and excludes value containing 'Onboarding'.");
result.put("items",items);
result.put("stats",stats);
result.put("debug",debug);
return result;
}